   grand_averages['win/learnable']
)
 
diff_unlearnable = compute_difference_wave(
   grand_averages['loss/unlearnable'],
   grand_averages['win/unlearnable']
)
 
 


#Measuring FRN Amplitude 
 
def measure_frn_amplitude(evoked, channel, tmin, tmax):
 
   ch_idx = evoked.ch_names.index(channel)
   times = evoked.times
   time_mask = (times >= tmin) & (times <= tmax) 
   amplitude = evoked.data[ch_idx, time_mask] 
   return np.mean(amplitude) * 1e6
   
