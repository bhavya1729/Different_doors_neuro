def load_all_epochs(preprocessed):
 
   pattern = os.path.join(preprocessed, '*_feedback_epochs-epo.fif')
   files   = sorted(glob.glob(pattern))
 
   if len(files) == 0:
       raise FileNotFoundError(
           f"No epoch files found at: {pattern}\n"
       )
 
   epochs_dict = {}
 
   for filepath in files:
       basename = os.path.basename(filepath)
       participant = basename.split('_')[0]
       epochs = mne.read_epochs(filepath, verbose=False, preload=True)
       epochs_dict[participant] = epochs
 
   participant_ids = sorted(epochs_dict.keys())
   print(f"Loaded epochs for {len(participant_ids)} participants")
 
   return epochs_dict, participant_ids
 
 
