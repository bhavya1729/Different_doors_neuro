       amp_loss = measure_frn_amplitude(evoked_loss, FRN_ELECTRODE, FRN_TMIN, FRN_TMAX)
 
       row[f'amp_win_{block_type}']  = amp_win
       row[f'amp_loss_{block_type}'] = amp_loss
