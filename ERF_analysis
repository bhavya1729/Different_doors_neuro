     f"SD={clean['frn_learnable'].std():.3f}")
print(f"FRN Unlearnable: mean={clean['frn_unlearnable'].mean():.3f} µV, "
     f"SD={clean['frn_unlearnable'].std():.3f}")
print(f"\nPaired t-test: t({n-1}) = {t_stat:.3f}, p = {p_val:.4f}")
# t(n-1): degrees of freedom for paired t-test = n - 1
print(f"Cohen's d = {cohens_d:.3f}")
print(f"Effect size: {'small' if abs(cohens_d) < 0.5 else 'medium' if abs(cohens_d) < 0.8 else 'large'}")
 
 
