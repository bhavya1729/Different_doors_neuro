#Computing individual Evoked objects and Grand Averages 
 
def compute_grand_averages(epochs_dict, participant_ids):
   
   all_conditions = list(epochs_dict[participant_ids[0]].event_id.keys())
   print(f"Conditions: {all_conditions}")
 
   individual_evokeds = {cond: [] for cond in all_conditions}
 
   for participant in participant_ids:
       epochs = epochs_dict[participant]
 
       for cond in all_conditions:
           if cond not in epochs.event_id:
               print(f"  Warning: {participant} missing condition '{cond}'")
               continue
 
           if len(epochs[cond]) == 0:
               print(f"  Warning: {participant} has 0 epochs for '{cond}'")
               continue
 
           evoked = epochs[cond].average()
           individual_evokeds[cond].append(evoked)
 
   grand_averages = {}
   for cond, evoked_list in individual_evokeds.items():
       if len(evoked_list) == 0:
           print(f"  Skipping {cond} — no data")
           continue
 
       grand_averages[cond] = mne.grand_average(evoked_list)
       print(f"  Grand average '{cond}': n={len(evoked_list)} participants")
 
   return individual_evokeds, grand_averages
 
 
individual_evokeds, grand_averages = compute_grand_averages(
   epochs_dict, participant_ids
)




# Computing Difference Waves
 
def compute_difference_wave(evoked_loss, evoked_win):


   diff = evoked_loss.copy()
 
   diff.data = evoked_loss.data - evoked_win.data
   return diff
 
 
