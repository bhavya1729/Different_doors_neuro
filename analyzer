    ax.plot(
       subset['trialNum'],        
       subset['mean_optimal'],    
       linewidth=2.5,
       label=condition           
   )
 
   # shade area to represent SEM of the mean
    ax.fill_between(
       subset['trialNum'],
       subset['mean_optimal'] - subset['sem_optimal'],  
       subset['mean_optimal'] + subset['sem_optimal'],  
