# win stay lose shift 
def cal_wsls(df):
   
 
   results = []
   
 
   for participant in df['participant'].unique():
      
 
       for condition in [1, 2]:
 
           subset = df[
               (df['participant'] == participant) &
               (df['condition'] == condition)
           ].sort_values(['blockNum', 'trialNum'])
           
 
          
           prev_outcome  = subset['outcome'].shift(1)
           prev_response = subset['response'].shift(1)
           prev_block    = subset['blockNum'].shift(1)
 
           
           stayed = (subset['response'].values == prev_response.values)
           
           same_block = (subset['blockNum'].values == prev_block.values)
           
 
           prev_win  = (prev_outcome.values == 1) & same_block
           prev_loss = (prev_outcome.values == 2) & same_block
           
 
           
           win_stay = stayed[prev_win].mean() if prev_win.sum() > 0 else np.nan
           
 
           lose_shift = (~stayed[prev_loss]).mean() if prev_loss.sum() > 0 else np.nan
           
 
           results.append({
               'participant': participant,
               'condition': condition,
               'condition_name': condition_labels[condition],
               'win_stay': win_stay,
               'lose_shift': lose_shift
           })
 
   return pd.DataFrame(results)
   
 
 
wsls = cal_wsls(responded)
 


learnable_ws   = wsls[wsls['condition'] == 2]['win_stay'].dropna()
unlearnable_ws = wsls[wsls['condition'] == 1]['win_stay'].dropna()


 
t_stat, p_val = stats.ttest_rel(learnable_ws, unlearnable_ws)


 
print(f"\nWin-stay: Learnable={learnable_ws.mean():.3f}, "
     f"Unlearnable={unlearnable_ws.mean():.3f}")
print(f"Paired t-test: t={t_stat:.3f}, p={p_val:.4f}")
 
 
